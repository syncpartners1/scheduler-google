# ── Google Apps Script ────────────────────────────────────────────────────────
# The Web App URL from your deployed Code.gs script.
# Used by the React frontend (VITE_ prefix) and the Express server proxy.
VITE_GAS_URL=https://script.google.com/macros/s/AKfycbywOVVMWMPiTmTXzB7F8rm7LZFpItdVHjTWd3eDCbP24lZUwMwDrtENg0GbINmSUSF0/exec
GAS_URL=https://script.google.com/macros/s/AKfycbywOVVMWMPiTmTXzB7F8rm7LZFpItdVHjTWd3eDCbP24lZUwMwDrtENg0GbINmSUSF0/exec

# ── Supabase (not used — bookings are stored in Google Sheet via GAS) ─────────
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ── Owner ─────────────────────────────────────────────────────────────────────
# Displayed in the app header ("Book a meeting with {name}")
VITE_OWNER_NAME=Your Name

# ── REST API ──────────────────────────────────────────────────────────────────
# Secret key required in X-Api-Key header for /api/* endpoints.
# Leave empty to disable auth (not recommended in production).
API_KEY=change-me-to-a-strong-secret

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# ── Railway internal ──────────────────────────────────────────────────────────
# Railway sets PORT automatically. Don't override unless testing locally.
# PORT=3000

# ── Server URL (for bot.js) ───────────────────────────────────────────────────
# The public URL of your Railway deployment.
# The Telegram bot calls /api/* internally via this URL.
SERVER_URL=https://abn-sch.up.railway.app
